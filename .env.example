# Database
DATABASE_URL=postgres://wherewewere:wherewewere@localhost:5432/wherewewere

# Server
PORT=3001
NODE_ENV=development

# Photos storage – absolute path; mount as a Docker volume in production
PHOTOS_DIR=/data/photos

# Session secret (change in production)
SESSION_SECRET=change-me-in-production

# Base URL (used for generating photo URLs)
BASE_URL=http://localhost:3001
