# Database
DATABASE_URL=postgres://wherewewere:wherewewere@localhost:5432/wherewewere

# Server
PORT=3001
NODE_ENV=development

# Session secret (change in production)
SESSION_SECRET=change-me-in-production

# Comma-separated allowed browser origins for CORS.
# Example: CORS_ORIGINS=https://journal.example.com,https://www.journal.example.com
CORS_ORIGINS=

# Optional API access token.
# If set, API requests must include X-WhereWeWere-Token with this exact value.
API_ACCESS_TOKEN=

# Set to true when running behind a reverse proxy (Traefik, Caddy, Nginx, etc).
TRUST_PROXY=false

# Web Push VAPID keys (required in production)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# Optional integrations (configure in-app as needed)
IMMICH_URL=
IMMICH_API_KEY=
MALOJA_URL=
DAWARICH_URL=
DAWARICH_API_KEY=
